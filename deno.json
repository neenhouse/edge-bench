{
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-env --unstable-kv --watch main.ts",
    "check": "deno check main.ts generate-map.ts",
    "test": "deno test --allow-net --allow-read --allow-env --unstable-kv",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "build": "deno task check && deno task lint && echo 'Build checks passed — ready for Deno Deploy'",
    "deploy": "deployctl deploy --project=edge-bench --prod main.ts"
  },
  "lint": {
    "exclude": ["static/"]
  }
}
